{
  "manifest_version": 3,
  "name": "Graph Trainer",
  "description": "Teach Graph how to use any webpage and run learned workflows.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Graph Trainer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "bootstrap.js",
        "assets/*.js",
        "assets/plugin/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
